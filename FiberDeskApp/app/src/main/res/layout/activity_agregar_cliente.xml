<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Registrar Nuevo Cliente"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_marginBottom="24dp"/>

            <!-- SECCIÓN DATOS PERSONALES -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--- Datos Personales ---"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre"/>
            <EditText
                android:id="@+id/etNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nombre del cliente"
                android:inputType="textPersonName"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Apellidos"/>
            <EditText
                android:id="@+id/etApellidos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Apellidos"
                android:inputType="textPersonName"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Teléfono"/>
            <EditText
                android:id="@+id/etTelefono"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Número a 10 dígitos"
                android:inputType="phone"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Correo Electrónico"/>
            <EditText
                android:id="@+id/etCorreo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="cliente@email.com"
                android:inputType="textEmailAddress"
                android:layout_marginBottom="32dp"/>


            <!-- SECCIÓN DIRECCIÓN POSTAL (MODIFICADA) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--- Dirección Postal ---"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <!-- Calle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Calle"/>
            <EditText
                android:id="@+id/etCalle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nombre de la calle"
                android:inputType="textPostalAddress"
                android:layout_marginBottom="16dp"/>

            <!-- Contenedor Horizontal para Números Ext e Int -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false"
                android:layout_marginBottom="16dp">

                <!-- Número Exterior -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Núm. Exterior"/>
                    <EditText
                        android:id="@+id/etNumExterior"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="#123"
                        android:inputType="textVisiblePassword"/>
                </LinearLayout>

                <!-- Número Interior -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Núm. Interior"/>
                    <EditText
                        android:id="@+id/etNumInterior"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Apto (Opcional)"
                        android:inputType="textVisiblePassword"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Código Postal -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Código Postal"/>
            <EditText
                android:id="@+id/etCP"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ej. 55120"
                android:inputType="number"
                android:maxLength="5"
                android:layout_marginBottom="16dp"/>

            <!-- Estado (Lista Desplegable) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Estado"/>

            <!-- IMPORTANTE: Este spinner carga la lista desde strings.xml -->
            <Spinner
                android:id="@+id/spinnerEstado"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:entries="@array/estados_mexico"
                android:layout_marginBottom="32dp"
                android:background="@android:drawable/btn_dropdown"/>


            <!-- SECCIÓN UBICACIÓN EXACTA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--- Ubicación Exacta ---"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/btnMapaManual"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🗺️ Seleccionar Punto en Mapa"
                android:backgroundTint="#FF9800"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnObtenerGPS"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📡 Usar mi ubicación actual"
                android:backgroundTint="#4CAF50"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <EditText
                    android:id="@+id/etLatitud"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:hint="Latitud"/>
                <EditText
                    android:id="@+id/etLongitud"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:hint="Longitud"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnVerMapa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📍 Verificar en Google Maps"
                android:backgroundTint="#2196F3"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/btnGuardar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Guardar Todo"
                android:layout_marginBottom="40dp"/>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
